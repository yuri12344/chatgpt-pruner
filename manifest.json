{
  "name": "Chat Pruner (ChatGPT)",
  "version": "1.9.1",
  "manifest_version": 3,
  "description": "Prune ChatGPT threads and block telemetry to reduce UI freezes.",
  "permissions": [
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://ab.chatgpt.com/*",
    "https://events.statsigapi.net/*",
    "*://*.statsigapi.net/*",
    "https://api.oaistatsig.com/*",
    "*://*.oaistatsig.com/*",
    "https://featuregates.org/*",
    "*://*.featuregates.org/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "block_telemetry",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "net-guard.js",
        "debounce.js",
        "profiler.js"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "scroll-patch.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_start"
    }
  ]
}
