{
  "name": "Chat Pruner (ChatGPT)",
  "version": "1.5.0",
  "manifest_version": 3,
  "description": "Poda conversas do ChatGPT e bloqueia telemetria para evitar travamentos.",
  "permissions": [
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://ab.chatgpt.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "block_telemetry",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "debounce.js",
        "profiler.js"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_start"
    }
  ]
}